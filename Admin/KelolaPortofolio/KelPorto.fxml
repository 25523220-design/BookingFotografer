<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="1200.0" style="-fx-background-color: #121212;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <HBox alignment="CENTER_LEFT" prefHeight="50.0" style="-fx-padding: 10 20 10 20;">
         <children>
            <Label text="Home  &gt;  Manajemen Konten  &gt;  " textFill="#888888" />
            <Label style="-fx-font-weight: bold;" text="Katalog Portofolio" textFill="#c5a880" />
            <Button style="-fx-background-color: #222222; -fx-text-fill: white; -fx-border-color: #444444;" text="⚙ Konfigurasi Galeri" />
         </children>
      </HBox>
      
      <HBox spacing="20.0" style="-fx-padding: 0 20 20 20;" VBox.vgrow="ALWAYS">
         <children>
            <VBox prefWidth="450.0" spacing="15.0" style="-fx-background-color: #1a1a1a; -fx-background-radius: 10; -fx-padding: 20;">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="⊕ Unggah Karya Baru" textFill="WHITE" />
                  
                  <VBox alignment="CENTER" prefHeight="150.0" style="-fx-border-color: #555555; -fx-border-style: dashed; -fx-border-radius: 8; -fx-background-color: #222222; -fx-background-radius: 8;">
                     <children>
                        <Label style="-fx-font-size: 30;" text="☁" textFill="#888888" />
                        <Label style="-fx-font-size: 12;" text="Tarik &amp; lepas file gambar foto di sini, atau pilih file" textFill="#cccccc" />
                        <Label style="-fx-font-size: 10;" text="Maks. ukuran berkas: 25MB (Format JPEG/PNG)" textFill="#666666" />
                     </children>
                  </VBox>
                  
                  <VBox spacing="5.0">
                     <children>
                        <Label style="-fx-font-size: 10; -fx-font-weight: bold;" text="JUDUL PUBLIKASI KARYA" textFill="#888888" />
                        <TextField style="-fx-background-color: #222222; -fx-text-fill: white; -fx-border-color: #444444;" text="" />
                     </children>
                  </VBox>
                  
                  <VBox spacing="5.0">
                     <children>
                        <Label style="-fx-font-size: 10; -fx-font-weight: bold;" text="KATEGORI PORTOFOLIO" textFill="#888888" />
                        <ComboBox maxWidth="Infinity" promptText="Premium Wedding" style="-fx-background-color: #222222; -fx-text-fill: white;" />
                     </children>
                  </VBox>
                  
                  <VBox spacing="5.0">
                     <children>
                        <Label style="-fx-font-size: 10; -fx-font-weight: bold;" text="LABEL &amp; KATA KUNCI (TAGS)" textFill="#888888" />
                        <TextField style="-fx-background-color: #222222; -fx-text-fill: white; -fx-border-color: #444444;" text="" />
                     </children>
                  </VBox>
                  <Button maxWidth="Infinity" prefHeight="40.0" style="-fx-background-color: #c5a880; -fx-text-fill: black; -fx-font-weight: bold;" text="💾 Simpan ke Portofolio" />
               </children>
            </VBox>
            
            <VBox spacing="15.0" style="-fx-background-color: #1a1a1a; -fx-background-radius: 10; -fx-padding: 20;" HBox.hgrow="ALWAYS">
               <children>
                  <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="🖼 Katalog Portofolio Aktif" textFill="WHITE" />
                  
                  <HBox spacing="15.0">
                     <children>
                        <VBox style="-fx-background-color: #222222; -fx-padding: 10; -fx-background-radius: 5;" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-font-size: 10;" text="TOTAL KARYA" textFill="#888888" />
                              <Label style="-fx-font-weight: bold;" text="124 Foto" textFill="WHITE" />
                           </children>
                        </VBox>
                        <VBox style="-fx-background-color: #222222; -fx-padding: 10; -fx-background-radius: 5;" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-font-size: 10;" text="UNGGULAN (FEATURED)" textFill="#888888" />
                              <Label style="-fx-font-weight: bold;" text="12 Karya" textFill="#c5a880" />
                           </children>
                        </VBox>
                        <VBox style="-fx-background-color: #222222; -fx-padding: 10; -fx-background-radius: 5;" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-font-size: 10;" text="KAPASITAS CLOUD" textFill="#888888" />
                              <Label style="-fx-font-weight: bold;" text="4.2 / 10 GB" textFill="WHITE" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
                  
                  <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-pane-background: transparent;" VBox.vgrow="ALWAYS">
                     <content>
                        <GridPane hgap="15.0" vgap="15.0">
                          <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                          </columnConstraints>
                           <children>
                              <VBox style="-fx-background-color: #222222; -fx-background-radius: 8; -fx-padding: 10;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                 <children>
                                    <StackPane prefHeight="120.0" style="-fx-background-color: #333333; -fx-background-radius: 5;" />
                                    <Label style="-fx-font-weight: bold; -fx-padding: 5 0 2 0;" text="Pra wedding and Wedding" textFill="WHITE" />
                                    <Label style="-fx-font-size: 11;" text="👁 1,420 Dilihat" textFill="#888888" />
                                 </children>
                              </VBox>
                              <VBox style="-fx-background-color: #222222; -fx-background-radius: 8; -fx-padding: 10;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                 <children>
                                    <StackPane prefHeight="120.0" style="-fx-background-color: #333333; -fx-background-radius: 5;" />
                                    <Label style="-fx-font-weight: bold; -fx-padding: 5 0 2 0;" text="Wisuda" textFill="WHITE" />
                                    <Label style="-fx-font-size: 11;" text="👁 982 Dilihat" textFill="#888888" />
                                 </children>
                              </VBox>
                           </children>
                           <rowConstraints>
                              <RowConstraints />
                           </rowConstraints>
                        </GridPane>
                     </content>
                  </ScrollPane>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
