<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="rootScroll" fitToWidth="true" fitToHeight="false" styleClass="root-scroll" stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.landstudio.AdminPaketController">
    <content>
        <HBox fx:id="pageBox" styleClass="page-shell">
            <!-- ===== SIDEBAR ADMIN ===== -->
            <VBox styleClass="admin-sidebar">
                <padding>
                    <Insets top="30" right="20" bottom="26" left="30"/>
                </padding>
                <Label text="LAND STUDIO" styleClass="admin-logo"/>
                <Label text="ADMIN" styleClass="admin-badge">
                    <VBox.margin>
                        <Insets top="12" bottom="30"/>
                    </VBox.margin>
                </Label>
                <VBox spacing="18">
                    <Label fx:id="navPesananLabel" text="Pesanan" styleClass="admin-nav" onMouseClicked="#goToPesanan"/>
                    <Label fx:id="navPaketLabel" text="Kelola Paket" styleClass="admin-nav" onMouseClicked="#goToKelolaPaket"/>
                </VBox>
                <Region VBox.vgrow="ALWAYS"/>
                <Label fx:id="adminNameLabel" text="Admin" styleClass="admin-user">
                    <VBox.margin>
                        <Insets bottom="12"/>
                    </VBox.margin>
                </Label>
                <Label text="Keluar" styleClass="admin-logout" onMouseClicked="#handleLogout"/>
            </VBox>

            <!-- ===== ISI ===== -->
            <VBox fx:id="pageMain" styleClass="page-main" HBox.hgrow="ALWAYS">
            <VBox styleClass="content-section" spacing="18">
                <padding>
                    <Insets top="30" right="48" bottom="60" left="48"/>
                </padding>

                <Label text="Kelola Paket" styleClass="page-title"/>
                <Label text="Tambah, ubah harga &amp; benefit, atau hapus paket. Perubahan langsung berlaku di halaman pelanggan."
                       styleClass="page-subtitle" wrapText="true"/>

                <HBox spacing="24" alignment="TOP_LEFT">

                    <!-- Kolom kiri: daftar paket -->
                    <VBox spacing="14" HBox.hgrow="ALWAYS">
                        <Label text="DAFTAR PAKET" styleClass="form-section-title"/>
                        <VBox fx:id="tierListContainer" spacing="12"/>
                    </VBox>

                    <!-- Kolom kanan: form tambah/edit -->
                    <VBox styleClass="booking-card" spacing="14" minWidth="360" maxWidth="420">
                        <Label fx:id="formTitleLabel" text="Tambah Paket Baru" styleClass="auth-title"/>
                        <Region styleClass="form-divider" minHeight="1" maxHeight="1"/>

                        <VBox spacing="6">
                            <Label text="Kategori" styleClass="form-label"/>
                            <ComboBox fx:id="kategoriCombo" editable="true" styleClass="form-input" maxWidth="Infinity"/>
                            <Label text="Pilih dari daftar atau ketik kategori baru." styleClass="stat-label"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="Nama Tier" styleClass="form-label"/>
                            <TextField fx:id="namaField" promptText="mis. Gold, Silver, Premium" styleClass="form-input"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="Harga (angka saja)" styleClass="form-label"/>
                            <TextField fx:id="hargaField" promptText="mis. 6000000" styleClass="form-input"/>
                        </VBox>
                        <VBox spacing="6">
                            <Label text="Periode" styleClass="form-label"/>
                            <TextField fx:id="periodeField" promptText="mis. / acara, / sesi, / paket" styleClass="form-input"/>
                        </VBox>
                        <CheckBox fx:id="unggulanCheck" text="Tandai sebagai paket unggulan"/>
                        <VBox spacing="6">
                            <Label text="Benefit (satu per baris)" styleClass="form-label"/>
                            <TextArea fx:id="fiturArea" promptText="Durasi sesi 8 jam&#10;80 foto hasil edit&#10;1 album cetak eksklusif"
                                      styleClass="form-input, form-textarea" prefRowCount="6" wrapText="true"/>
                        </VBox>

                        <Label fx:id="statusLabel" styleClass="form-status" wrapText="true"/>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Button fx:id="simpanButton" text="TAMBAH PAKET" styleClass="btn-gold" onAction="#handleSave"/>
                            <Button text="RESET" styleClass="btn-outline-dark" onAction="#handleReset"/>
                        </HBox>
                    </VBox>

                </HBox>
            </VBox>

            </VBox>
        </HBox>
    </content>
</ScrollPane>
