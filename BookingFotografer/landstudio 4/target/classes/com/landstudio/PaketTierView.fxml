<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="rootScroll" fitToWidth="true" fitToHeight="false" styleClass="root-scroll" stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.landstudio.PaketTierController">
    <content>
                <HBox fx:id="pageBox" styleClass="page-shell">
            <!-- ===================== SIDEBAR KIRI ===================== -->
            <VBox styleClass="sidebar">
                <padding>
                    <Insets top="30" right="24" bottom="30" left="30"/>
                </padding>
                <Label text="LAND STUDIO" styleClass="logo"/>
                <Label fx:id="userNameLabel" text="MASUK / DAFTAR" styleClass="user-name">
                    <VBox.margin>
                        <Insets top="16" bottom="30"/>
                    </VBox.margin>
                </Label>
                <VBox styleClass="nav-vertical" spacing="20">
                    <Label text="BERANDA" styleClass="nav-item" onMouseClicked="#goToBeranda"/>
                    <Label text="PORTOFOLIO" styleClass="nav-item" onMouseClicked="#goToPortfolio"/>
                    <Label text="BOOKING" styleClass="nav-item" onMouseClicked="#goToBooking"/>
                    <Label text="PAKET" styleClass="nav-item, nav-active" onMouseClicked="#goToPaket"/>
                </VBox>
            </VBox>
            <VBox fx:id="pageMain" styleClass="page-main" HBox.hgrow="ALWAYS">

            <!-- ===================== HERO KATEGORI (foto + judul) ===================== -->
            <StackPane fx:id="heroPane" styleClass="card" prefHeight="260">
                <Region styleClass="card-overlay"/>
                <VBox alignment="BOTTOM_LEFT" styleClass="card-content">
                    <padding>
                        <Insets top="0" right="32" bottom="28" left="32"/>
                    </padding>
                    <Label fx:id="categoryNumberLabel" text="01" styleClass="card-number"/>
                    <Label fx:id="categoryTitleLabel" text="Pernikahan" styleClass="card-title"/>
                    <Label fx:id="categorySubtitleLabel"
                           text="Pilih salah satu tier paket untuk melihat rincian lengkapnya."
                           styleClass="card-desc" wrapText="true"/>
                </VBox>
            </StackPane>

            <!-- ===================== LABEL "KEMBALI" ===================== -->
            <HBox alignment="CENTER_LEFT" styleClass="content-section">
                <padding>
                    <Insets top="24" right="60" bottom="0" left="60"/>
                </padding>
                <Label text="&#8592;  Kembali ke Kategori" styleClass="back-link" onMouseClicked="#goToPaket"/>
            </HBox>

            <!-- ===================== JUDUL ===================== -->
            <VBox alignment="CENTER" spacing="10" styleClass="content-section">
                <padding>
                    <Insets top="20" right="60" bottom="8" left="60"/>
                </padding>
                <Label text="Pilih Tier Paket" styleClass="page-title"/>
                <Label text="Tekan LIHAT DETAIL untuk melihat harga lengkap, benefit, dan tombol booking."
                       styleClass="page-subtitle" wrapText="true" textAlignment="CENTER"/>
            </VBox>

            <!-- ===================== DAFTAR TIER (diisi lewat Java) ===================== -->
            <VBox alignment="CENTER" styleClass="content-section">
                <padding>
                    <Insets top="12" right="60" bottom="70" left="60"/>
                </padding>
                <VBox fx:id="tierListContainer" spacing="16" maxWidth="720"/>
            </VBox>

            <!-- ===================== FOOTER ===================== -->
            <VBox styleClass="footer" alignment="CENTER" spacing="10">
                <padding>
                    <Insets top="50" bottom="50"/>
                </padding>
                <Label text="LAND STUDIO" styleClass="footer-logo"/>
                <Label text="© 2026 TEMAN STUDIO. Seluruh hak cipta dilindungi undang-undang." styleClass="footer-text"/>
            </VBox>

            </VBox>
        </HBox>
    </content>
</ScrollPane>
