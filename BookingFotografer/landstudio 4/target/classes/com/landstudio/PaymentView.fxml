<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="rootScroll" fitToWidth="true" fitToHeight="false" styleClass="root-scroll" stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.landstudio.PaymentController">
    <content>
        <VBox fx:id="pageBox" styleClass="page">

            <VBox alignment="CENTER" spacing="8" styleClass="content-section">
                <padding>
                    <Insets top="26" bottom="10"/>
                </padding>
                <Label text="LAND STUDIO" styleClass="logo"/>
                <Label text="&#8592;  Kembali ke Beranda" styleClass="back-link" onMouseClicked="#goToBeranda"/>
            </VBox>

            <VBox alignment="CENTER" spacing="10" styleClass="content-section">
                <padding>
                    <Insets top="6" right="60" bottom="16" left="60"/>
                </padding>
                <Label text="Pembayaran Booking" styleClass="page-title"/>
                <Label text="Selesaikan pembayaran untuk mengonfirmasi jadwal sesi foto Anda."
                       styleClass="page-subtitle" wrapText="true" textAlignment="CENTER" alignment="CENTER"/>
            </VBox>

            <VBox alignment="CENTER" styleClass="content-section">
                <padding>
                    <Insets top="0" right="60" bottom="70" left="60"/>
                </padding>
                <VBox styleClass="booking-card" spacing="26" maxWidth="620">

                    <!-- ===== RINGKASAN PESANAN ===== -->
                    <VBox spacing="14">
                        <Label text="RINGKASAN PESANAN" styleClass="form-section-title"/>
                        <GridPane hgap="16" vgap="10">
                            <Label text="Paket" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <Label fx:id="ringkasanPaket" text="-" styleClass="price-feature" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <Label text="Tanggal" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <Label fx:id="ringkasanTanggal" text="-" styleClass="price-feature" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            <Label text="Jam" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <Label fx:id="ringkasanJam" text="-" styleClass="price-feature" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            <Label text="Atas Nama" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <Label fx:id="ringkasanNama" text="-" styleClass="price-feature" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                        </GridPane>
                        <Region styleClass="form-divider" minHeight="1" maxHeight="1"/>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="TOTAL TAGIHAN" styleClass="form-section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="ringkasanTotal" text="Rp 0" styleClass="price-value"/>
                        </HBox>
                    </VBox>

                    <Region styleClass="form-divider" minHeight="1" maxHeight="1"/>

                    <!-- ===== METODE PEMBAYARAN ===== -->
                    <VBox fx:id="metodeSection" spacing="18">
                        <Label text="PILIH METODE PEMBAYARAN" styleClass="form-section-title"/>
                        <HBox spacing="16" alignment="CENTER">
                            <Label fx:id="tabQrisLabel" text="QRIS" styleClass="payment-tab" onMouseClicked="#selectQris"/>
                            <Label fx:id="tabTransferLabel" text="TRANSFER BANK" styleClass="payment-tab" onMouseClicked="#selectTransfer"/>
                        </HBox>

                        <!-- ===== QRIS PANE ===== -->
                        <VBox fx:id="qrisPane" alignment="CENTER" spacing="14" styleClass="payment-panel">
                            <Label text="Pindai kode QRIS berikut menggunakan aplikasi e-wallet atau m-banking Anda."
                                   styleClass="page-subtitle" wrapText="true" textAlignment="CENTER" alignment="CENTER" maxWidth="420"/>
                            <HBox alignment="CENTER">
                                <VBox alignment="CENTER" styleClass="qr-box">
                                    <GridPane fx:id="qrGrid" alignment="CENTER" hgap="0" vgap="0"/>
                                </VBox>
                            </HBox>
                            <Label text="QRIS - LAND STUDIO" styleClass="form-label"/>
                            <Label fx:id="qrAmountLabel" text="Total: Rp 0" styleClass="price-feature" alignment="CENTER"/>
                        </VBox>

                        <!-- ===== TRANSFER PANE ===== -->
                        <VBox fx:id="transferPane" spacing="12" styleClass="payment-panel" visible="false" managed="false">
                            <Label text="Transfer ke salah satu rekening berikut, lalu klik konfirmasi di bawah."
                                   styleClass="page-subtitle" wrapText="true"/>
                            <VBox styleClass="bank-row" spacing="4">
                                <Label text="Bank BCA" styleClass="form-label"/>
                                <Label text="1234567890 a.n. Land Studio Indonesia" styleClass="price-feature"/>
                            </VBox>
                            <VBox styleClass="bank-row" spacing="4">
                                <Label text="Bank Mandiri" styleClass="form-label"/>
                                <Label text="0987654321 a.n. Land Studio Indonesia" styleClass="price-feature"/>
                            </VBox>
                            <Label fx:id="transferAmountLabel" text="Total: Rp 0" styleClass="price-feature"/>
                        </VBox>
                    </VBox>

                    <!-- ===== TOMBOL KONFIRMASI ===== -->
                    <HBox fx:id="konfirmasiBox" alignment="CENTER">
                        <Button text="KONFIRMASI PEMBAYARAN" styleClass="btn-gold" maxWidth="Infinity" onAction="#handleConfirmPayment"/>
                    </HBox>

                    <!-- ===== SUCCESS PANE ===== -->
                    <VBox fx:id="successPane" alignment="CENTER" spacing="14">
                        <Label text="&#10004;" styleClass="success-icon"/>
                        <Label text="Booking Berhasil Dikonfirmasi!" styleClass="auth-title"/>
                        <Label text="Tim kami akan menyiapkan sesi foto sesuai jadwal yang Anda pilih."
                               styleClass="page-subtitle" wrapText="true" textAlignment="CENTER" alignment="CENTER"/>
                        <Label fx:id="successIdLabel" text="Kode Booking: -" styleClass="form-label"/>
                        <HBox spacing="14" alignment="CENTER">
                            <padding>
                                <Insets top="10"/>
                            </padding>
                            <Button text="UNDUH BUKTI BOOKING" styleClass="btn-outline-dark" onAction="#handleDownloadBukti"/>
                            <Button text="KEMBALI KE BERANDA" styleClass="btn-gold" onAction="#goToBeranda"/>
                        </HBox>
                    </VBox>

                </VBox>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
