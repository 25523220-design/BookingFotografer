<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="rootScroll" fitToWidth="true" fitToHeight="false" styleClass="root-scroll" stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.landstudio.PaketController">
    <content>
        <VBox fx:id="pageBox" styleClass="page">

            <!-- ===================== HEADER ===================== -->
            <HBox styleClass="header" alignment="CENTER_LEFT" spacing="0">
                <padding>
                    <Insets top="18" right="60" bottom="18" left="60"/>
                </padding>
                <Label text="LAND STUDIO" styleClass="logo"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="36" styleClass="nav">
                    <Label text="BERANDA" styleClass="nav-item" onMouseClicked="#goToBeranda"/>
                    <Label text="PORTOFOLIO" styleClass="nav-item" onMouseClicked="#goToPortfolio"/>
                    <Label text="BOOKING" styleClass="nav-item" onMouseClicked="#goToBooking"/>
                    <VBox alignment="CENTER" spacing="4">
                        <Label text="PAKET" styleClass="nav-item, nav-active"/>
                        <Region styleClass="nav-underline"/>
                    </VBox>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="userNameLabel" text="MASUK / DAFTAR" styleClass="user-name"/>
            </HBox>
            <Region styleClass="header-divider" minHeight="1" maxHeight="1"/>

            <!-- ===================== JUDUL HALAMAN ===================== -->
            <VBox alignment="CENTER" spacing="10" styleClass="content-section">
                <padding>
                    <Insets top="56" right="60" bottom="16" left="60"/>
                </padding>
                <Label text="Paket Layanan" styleClass="page-title"/>
                <Label text="Pilih kategori sesi foto untuk melihat rincian paket dan harga."
                       styleClass="page-subtitle" wrapText="true" textAlignment="CENTER"/>
            </VBox>

            <!-- ===================== KATEGORI PAKET (A / B / C) ===================== -->
            <VBox styleClass="content-section" spacing="24">
                <padding>
                    <Insets top="16" right="60" bottom="70" left="60"/>
                </padding>

                <!-- KATEGORI: Pernikahan -->
                <StackPane fx:id="catPernikahan" styleClass="card, card-bg-1" prefHeight="280">
                    <Region styleClass="card-overlay"/>
                    <VBox alignment="BOTTOM_LEFT" styleClass="card-content">
                        <padding>
                            <Insets top="0" right="32" bottom="28" left="32"/>
                        </padding>
                        <Label text="01" styleClass="card-number"/>
                        <Label text="Pernikahan" styleClass="card-title"/>
                        <Label text="Menangkap simfoni emosi dalam penyatuan paling sakral Anda dengan kualitas sinematik yang abadi."
                               styleClass="card-desc" wrapText="true"/>
                        <HBox>
                            <padding>
                                <Insets top="14"/>
                            </padding>
                            <Button text="LIHAT PAKET" styleClass="btn-gold" onAction="#openPernikahan"/>
                        </HBox>
                    </VBox>
                </StackPane>

                <!-- KATEGORI: Wisuda -->
                <StackPane fx:id="catWisuda" styleClass="card, card-bg-2" prefHeight="280">
                    <Region styleClass="card-overlay"/>
                    <VBox alignment="BOTTOM_LEFT" styleClass="card-content">
                        <padding>
                            <Insets top="0" right="32" bottom="28" left="32"/>
                        </padding>
                        <Label text="02" styleClass="card-number"/>
                        <Label text="Wisuda" styleClass="card-title"/>
                        <Label text="Mendokumentasikan puncak pencapaian akademik dengan gaya yang elegan dan berkesan."
                               styleClass="card-desc" wrapText="true"/>
                        <HBox>
                            <padding>
                                <Insets top="14"/>
                            </padding>
                            <Button text="LIHAT PAKET" styleClass="btn-gold" onAction="#openWisuda"/>
                        </HBox>
                    </VBox>
                </StackPane>

                <!-- KATEGORI: Pre-Wedding -->
                <StackPane fx:id="catPreWedding" styleClass="card, card-bg-3" prefHeight="280">
                    <Region styleClass="card-overlay"/>
                    <VBox alignment="BOTTOM_LEFT" styleClass="card-content">
                        <padding>
                            <Insets top="0" right="32" bottom="28" left="32"/>
                        </padding>
                        <Label text="03" styleClass="card-number"/>
                        <Label text="Pre-Wedding" styleClass="card-title"/>
                        <Label text="Narasi intim yang ditangkap dalam momen tenang sebelum perayaan agung. Refleksi dari chemistry unik Anda."
                               styleClass="card-desc" wrapText="true"/>
                        <HBox>
                            <padding>
                                <Insets top="14"/>
                            </padding>
                            <Button text="LIHAT PAKET" styleClass="btn-gold" onAction="#openPreWedding"/>
                        </HBox>
                    </VBox>
                </StackPane>

            </VBox>

            <!-- ===================== FOOTER ===================== -->
            <VBox styleClass="footer" alignment="CENTER" spacing="10">
                <padding>
                    <Insets top="50" bottom="50"/>
                </padding>
                <Label text="LAND STUDIO" styleClass="footer-logo"/>
                <Label text="© 2026 TEMAN STUDIO. Seluruh hak cipta dilindungi undang-undang." styleClass="footer-text"/>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
