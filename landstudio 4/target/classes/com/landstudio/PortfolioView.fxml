<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fx:id="rootScroll" fitToWidth="true" fitToHeight="false" styleClass="root-scroll" stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.landstudio.PortfolioController">
    <content>
        <VBox fx:id="pageBox" styleClass="page">

            <!-- ===================== HEADER ===================== -->
            <HBox styleClass="header" alignment="CENTER_LEFT" spacing="0">
                <padding>
                    <Insets top="18" right="60" bottom="18" left="60"/>
                </padding>
                <Label text="LAND STUDIO" styleClass="logo"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox alignment="CENTER" spacing="36" styleClass="nav">
                    <Label text="BERANDA" styleClass="nav-item" onMouseClicked="#goToBeranda"/>
                    <VBox alignment="CENTER" spacing="4">
                        <Label text="PORTOFOLIO" styleClass="nav-item, nav-active"/>
                        <Region styleClass="nav-underline"/>
                    </VBox>
                    <Label text="BOOKING" styleClass="nav-item" onMouseClicked="#goToBooking"/>
                    <Label text="PAKET" styleClass="nav-item" onMouseClicked="#goToPaket"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="userNameLabel" text="MASUK / DAFTAR" styleClass="user-name"/>
            </HBox>
            <Region styleClass="header-divider" minHeight="1" maxHeight="1"/>

            <!-- ===================== JUDUL HALAMAN ===================== -->
            <VBox alignment="CENTER" spacing="10" styleClass="content-section">
                <padding>
                    <Insets top="56" right="60" bottom="24" left="60"/>
                </padding>
                <Label text="Portofolio Kami" styleClass="page-title"/>
                <Label text="Kumpulan momen yang telah kami abadikan untuk klien kami."
                       styleClass="page-subtitle" wrapText="true" textAlignment="CENTER" alignment="CENTER"/>
            </VBox>

            <!-- ===================== BARIS ATAS: Pernikahan + Pre-Wedding ===================== -->
            <VBox styleClass="content-section" spacing="24">
                <padding>
                    <Insets top="12" right="60" bottom="24" left="60"/>
                </padding>
                <HBox spacing="24">
                    <StackPane fx:id="cardPernikahan" styleClass="card, card-bg-1" HBox.hgrow="ALWAYS">
                        <Region styleClass="card-overlay"/>
                        <VBox alignment="BOTTOM_LEFT" styleClass="card-content">
                            <padding>
                                <Insets top="0" right="28" bottom="26" left="28"/>
                            </padding>
                            <Label text="EKSKLUSIF" styleClass="badge-tag"/>
                            <Label text="Pernikahan" styleClass="card-title"/>
                            <HBox>
                                <padding>
                                    <Insets top="12"/>
                                </padding>
                                <Button text="DETAIL PAKET" styleClass="btn-outline" onAction="#openTierPernikahan"/>
                            </HBox>
                        </VBox>
                    </StackPane>
                    <StackPane fx:id="cardPreWedding" styleClass="card, card-bg-3" HBox.hgrow="ALWAYS">
                        <Region styleClass="card-overlay"/>
                        <VBox alignment="BOTTOM_LEFT" styleClass="card-content">
                            <padding>
                                <Insets top="0" right="28" bottom="26" left="28"/>
                            </padding>
                            <Label text="ARTISTIS" styleClass="badge-tag"/>
                            <Label text="Pre-Wedding" styleClass="card-title"/>
                            <HBox>
                                <padding>
                                    <Insets top="12"/>
                                </padding>
                                <Button text="DETAIL PAKET" styleClass="btn-outline" onAction="#openTierPreWedding"/>
                            </HBox>
                        </VBox>
                    </StackPane>
                </HBox>

                <!-- ===================== BARIS BAWAH: Wisuda ===================== -->
                <HBox spacing="24">
                    <StackPane fx:id="cardWisuda" styleClass="card, card-bg-2" HBox.hgrow="ALWAYS" prefHeight="280">
                        <Region styleClass="card-overlay"/>
                        <VBox alignment="BOTTOM_LEFT" styleClass="card-content">
                            <padding>
                                <Insets top="0" right="24" bottom="22" left="24"/>
                            </padding>
                            <Label text="Wisuda" styleClass="card-title-sm"/>
                            <Label text="Rayakan pencapaian akademik Anda dengan penuh gaya."
                                   styleClass="card-desc" wrapText="true"/>
                            <HBox>
                                <padding>
                                    <Insets top="12"/>
                                </padding>
                                <Button text="DETAIL PAKET" styleClass="btn-outline" onAction="#openTierWisuda"/>
                            </HBox>
                        </VBox>
                    </StackPane>
                </HBox>
            </VBox>

            <!-- ===================== FOOTER ===================== -->
            <VBox styleClass="footer" alignment="CENTER" spacing="10">
                <padding>
                    <Insets top="50" bottom="50"/>
                </padding>
                <Label text="LAND STUDIO" styleClass="footer-logo"/>
                <Label text="© 2026 TEMAN STUDIO. Seluruh hak cipta dilindungi undang-undang." styleClass="footer-text"/>
            </VBox>

        </VBox>
    </content>
</ScrollPane>
